# Lingua ortam degiskenleri ornegi.
# Gercek anahtarlar kok .env dosyasina yazilir; .env GITIGNORE'dadir, GitHub'a gitmez.
# Bu .env.example ise repoya girer (sadece anahtar isimlerini gosterir, deger tutmaz).

# Kelime formundaki "AI ile doldur" ozelligi icin (opsiyonel).
# Yoksa ozellik AI onerisi vermez; dusuk kaliteli sozluk/ceviri fallback'i yoktur.
# Ucretsiz anahtar: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opsiyonel: Gemini modellerini deneme sirasina gore virgulle ayir.
# Bos birakilirsa backend guvenli varsayilani kullanir.
# Ornek: AI_GEMINI_MODELS=gemini-3.5-flash,gemini-3-flash,gemini-2.5-flash
AI_GEMINI_MODELS=

# Opsiyonel lokal cache: ayni kelime/anlam icin tekrar Gemini kotasi harcanmasin.
# Varsayilan true kabul edilir.
AI_CACHE_ENABLED=true

# (Opsiyonel, su an kullanilmiyor; ileride HF provider icin ayrildi)
HUGGINGFACE_TOKEN=

# Opsiyonel: manuel AI model degerlendirme script'i icin.
# cd backend
# .venv\Scripts\python.exe scripts\evaluate_ai_providers.py
AI_EVAL_GEMINI_MODELS=
AI_HF_MODELS=
